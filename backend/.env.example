# ─────────────────────────────────────────
# LearnHub Backend Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# IMPORTANT: Change this to a long, random string in production!
JWT_SECRET=learnhub-change-this-secret-in-production-min-32-chars

# Google OAuth (leave blank to keep stub/disabled)
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────
# LearnHub Backend Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Database (SQLite)
# For local dev, use file:learnhub.db
# For production (Turso), use libpsql://...
DATABASE_URL=file:learnhub.db
DATABASE_AUTH_TOKEN=

# Authentication
# IMPORTANT: Change this to a long, random string in production!
JWT_SECRET=learnhub-change-this-secret-in-production-min-32-chars

# Google OAuth (leave blank to keep stub/disabled)
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payments (Stripe)
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
